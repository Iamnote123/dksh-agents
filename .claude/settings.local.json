{
  "env": {
    "ENABLE_TOOL_SEARCH": "true",
    "DISABLE_AUTOUPDATER": "1"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/session_start_reminder.py",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/protocol_reminder.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/protect_inputs.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/block_dangerous_bash.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/log_writes.py",
            "async": true,
            "timeout": 5
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "PowerShell(git clone *)",
      "Bash(rm -rf /tmp/xlsm_inspect)",
      "Bash(mkdir -p /tmp/xlsm_inspect)",
      "Bash(unzip -o -q Athithep_Chaiyakul_YTD_May26_FY26.xlsm -d /tmp/xlsm_inspect)",
      "Read(//tmp/**)",
      "Bash(python -)"
    ]
  }
}

